# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Optional: separate source collection for raw documents
# SOURCE_MONGODB_URI=mongodb+srv://...
# SOURCE_DB=rag_source

# Destination database / collection
DB_NAME=rag_pipeline
COLLECTION_NAME=chunks

# OpenAI API key (required for embedding generation)
OPENAI_API_KEY=sk-...
